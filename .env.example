# App settings
SECRET_KEY=change-me

# MongoDB connection settings
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DB=taskman_db
MONGODB_USERNAME=
MONGODB_PASSWORD=
# Or use full URI (takes precedence if set)
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/taskman_db

# MongoDB connection pool settings
MONGODB_MAX_POOL_SIZE=100
MONGODB_MIN_POOL_SIZE=0
MONGODB_MAX_IDLE_TIME_MS=10000

# MongoDB timeout settings (milliseconds)
MONGODB_CONNECT_TIMEOUT_MS=5000
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000

# MongoDB SSL/TLS settings
MONGODB_TLS=false
MONGODB_TLS_ALLOW_INVALID_CERT=false
MONGODB_AUTH_SOURCE=admin

# JWT settings
JWT_EXPIRES_MINUTES=60
